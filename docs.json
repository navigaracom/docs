{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Navigara Documentation",
  "colors": {
    "primary": "#0C8C5E",
    "light": "#18E299",
    "dark": "#0C8C5E"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/performance-and-alignment"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/github",
              "integrations/gitlab",
              "integrations/linear",
              "integrations/jira"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/overview",
              "deployment/on-prem-collector",
              "deployment/full-on-premises"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://navigara.com",
          "icon": "globe"
        },
        {
          "anchor": "Blog",
          "href": "https://navigara.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@navigara.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.navigara.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/navigara",
      "github": "https://github.com/navigaracom",
      "linkedin": "https://linkedin.com/company/navigara"
    }
  }
}
